# Disable PHP execution in uploads directory
<FilesMatch "\.(?:php|phtml|php3|php4|php5|php7|phps|cgi|pl|asp|aspx|shtml|shtm|fcgi|fpl|py|rb|sh|bat|cmd|com|vbs|js|ws|wsf)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

# Disable directory listing
Options -Indexes

# Only allow specific file types
<FilesMatch "\.(?:jpg|jpeg|png|gif|webp|pdf|doc|docx|xls|xlsx)$">
    Allow from all
</FilesMatch>
